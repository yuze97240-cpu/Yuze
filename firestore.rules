rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Profiles shouldn't be listable by anyone
      allow create, update: if isOwner(userId) && 
        incoming().uid == userId && 
        incoming().email is string &&
        incoming().keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt']) &&
        incoming().keys().size() == 5;
    }

    // Thought Rules
    match /thoughts/{thoughtId} {
      function isValidThought(data) {
        return data.userId == request.auth.uid &&
               data.content is string && data.content.size() <= 2000 &&
               data.sentiment is string &&
               data.imagery is list && data.imagery.size() <= 10 &&
               data.createdAt == request.time;
      }

      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidThought(incoming());
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Matches Subcollection
      match /matches/{matchId} {
        allow get: if isSignedIn() && get(/databases/$(database)/documents/thoughts/$(thoughtId)).data.userId == request.auth.uid;
        allow list: if isSignedIn() && get(/databases/$(database)/documents/thoughts/$(thoughtId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/thoughts/$(thoughtId)).data.userId == request.auth.uid;
      }
    }
  }
}
